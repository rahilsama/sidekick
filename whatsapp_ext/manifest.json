{
    "manifest_version": 3,
    "name": "Sidekick for WhatsApp Web",
    "version": "1.0",
    "description": "Automatically generates replies based on WhatsApp Web chat history.",
    "permissions": [
        "activeTab"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://web.whatsapp.com/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "styles.css"
            ]
        }
    ],
    "host_permissions": [
        "http://localhost:8000/*",
        "http://127.0.0.1:8000/*"
    ]
}